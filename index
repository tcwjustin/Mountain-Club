<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>想山享山 · 登山社</title>
<link rel="manifest" href="./manifest.webmanifest">
<meta name="theme-color" content="#1d4233">
<link rel="icon" href="./favicon-32.png" sizes="32x32">
<link rel="apple-touch-icon" href="./icon-180.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="想山享山">
<style>
:root{
  --pine:#0f211a; --fir:#1d4233; --moss:#356b4f; --bamboo:#9aae6b;
  --mist:#e9efe7; --cloud:#f6f8f3; --alpen:#cf8233; --alpen-soft:#e7b06a;
  --ridge:#5f7375; --stone:#aab4a8; --ink:#15211c;
  --line:rgba(15,33,26,.12); --line-soft:rgba(15,33,26,.07);
  --font-display:"Songti TC","STSong","Source Han Serif TC","Noto Serif TC","Noto Serif CJK TC",serif;
  --font-body:"PingFang TC","Noto Sans TC","Noto Sans CJK TC","Microsoft JhengHei",system-ui,sans-serif;
  --font-data:"SFMono-Regular","SF Mono","Roboto Mono","JetBrains Mono",ui-monospace,monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:var(--font-body); color:var(--ink); background:var(--mist);
  line-height:1.6; -webkit-font-smoothing:antialiased; min-height:100vh;
}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,select,textarea{font-family:inherit;font-size:1rem}
a{color:inherit}
:focus-visible{outline:2px solid var(--alpen);outline-offset:2px;border-radius:3px}

/* ============ Ambient ridgeline background ============ */
#sky{position:fixed;inset:0;z-index:-2;overflow:hidden;
  background:linear-gradient(180deg,#cdd9d0 0%,#dde6dc 30%,var(--mist) 70%);}
#sky .ridge{position:absolute;left:-5%;width:110%;bottom:0;will-change:transform}
#sky svg{display:block;width:100%;height:auto}
.fog{position:fixed;inset:0;z-index:-1;pointer-events:none;
  background:radial-gradient(120% 60% at 50% 100%, rgba(246,248,243,0) 40%, rgba(246,248,243,.55) 100%);}
.fog::before{content:"";position:absolute;inset:-20% -20% auto -20%;height:55%;
  background:radial-gradient(60% 100% at 30% 40%, rgba(255,255,255,.5), transparent 70%),
             radial-gradient(50% 100% at 75% 30%, rgba(255,255,255,.4), transparent 70%);
  animation:drift 60s linear infinite;}
@keyframes drift{from{transform:translateX(-4%)}50%{transform:translateX(4%)}to{transform:translateX(-4%)}}

/* ============ Login ============ */
#login{position:fixed;inset:0;z-index:50;display:flex;align-items:center;justify-content:center;
  background:linear-gradient(180deg, rgba(10,22,17,.55), rgba(10,22,17,.78));padding:24px}
#login .panel{background:rgba(246,248,243,.96);backdrop-filter:blur(6px);
  border-radius:18px;padding:clamp(28px,5vw,48px);width:min(420px,100%);
  box-shadow:0 30px 80px rgba(8,20,14,.45);border:1px solid rgba(255,255,255,.5)}
#login .mark{font-family:var(--font-data);letter-spacing:.45em;font-size:.7rem;
  color:var(--moss);text-transform:uppercase;margin-bottom:14px}
#login h1{font-family:var(--font-display);font-size:2.6rem;font-weight:700;color:var(--pine);
  line-height:1.05;margin-bottom:6px;letter-spacing:.04em}
#login .sub{color:var(--ridge);font-size:.92rem;margin-bottom:26px}
.field{margin-bottom:16px}
.field label{display:block;font-size:.78rem;color:var(--moss);margin-bottom:6px;letter-spacing:.05em}
.field input{width:100%;padding:12px 14px;border:1px solid var(--line);border-radius:10px;
  background:#fff;transition:border-color .2s}
.field input:focus{border-color:var(--moss);outline:none}
.btn-primary{width:100%;background:var(--fir);color:var(--cloud);padding:13px;border-radius:10px;
  font-weight:600;letter-spacing:.08em;transition:background .2s,transform .1s}
.btn-primary:hover{background:var(--pine)}.btn-primary:active{transform:translateY(1px)}
.btn-ghost{width:100%;margin-top:10px;padding:11px;border-radius:10px;color:var(--moss);
  border:1px solid var(--line);transition:background .2s}
.btn-ghost:hover{background:rgba(53,107,79,.08)}
#login .note{margin-top:18px;font-size:.74rem;color:var(--stone);line-height:1.5;text-align:center}

/* ============ App shell ============ */
#app{display:none;min-height:100vh}
#app.on{display:block}
.topbar{position:sticky;top:0;z-index:30;display:flex;align-items:center;gap:18px;
  padding:14px clamp(16px,4vw,40px);
  background:rgba(15,33,26,.92);backdrop-filter:blur(10px);color:var(--mist);
  border-bottom:1px solid rgba(255,255,255,.08)}
.brand{font-family:var(--font-display);font-size:1.4rem;letter-spacing:.12em;font-weight:700}
.brand small{font-family:var(--font-data);font-size:.6rem;letter-spacing:.4em;
  display:block;color:var(--bamboo);font-weight:400;margin-top:-2px}
.nav{display:flex;gap:4px;margin-left:auto;flex-wrap:wrap}
.nav button{padding:8px 14px;border-radius:8px;font-size:.9rem;color:rgba(233,239,231,.72);
  transition:background .2s,color .2s}
.nav button:hover{color:#fff;background:rgba(255,255,255,.07)}
.nav button.active{color:var(--pine);background:var(--bamboo)}
.who{display:flex;align-items:center;gap:10px;padding-left:14px;margin-left:6px;
  border-left:1px solid rgba(255,255,255,.12)}
.who .avatar{width:32px;height:32px;border-radius:50%;background:var(--moss);color:#fff;
  display:grid;place-items:center;font-weight:700;font-family:var(--font-display)}
.who .nm{font-size:.85rem}.who .ro{font-size:.65rem;color:var(--bamboo);font-family:var(--font-data);letter-spacing:.1em}
.logout{font-size:.7rem;color:rgba(233,239,231,.5);margin-left:4px}
.logout:hover{color:var(--alpen-soft)}
.menu-toggle{display:none}

main{max-width:1180px;margin:0 auto;padding:clamp(20px,4vw,44px) clamp(16px,4vw,40px) 90px}
.view{display:none;animation:rise .5s ease both}
.view.on{display:block}
@keyframes rise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}

.eyebrow{font-family:var(--font-data);font-size:.7rem;letter-spacing:.4em;color:var(--moss);
  text-transform:uppercase;margin-bottom:8px}
.h-title{font-family:var(--font-display);font-size:clamp(1.9rem,4vw,2.8rem);color:var(--pine);
  letter-spacing:.04em;line-height:1.1;margin-bottom:6px}
.h-sub{color:var(--ridge);max-width:60ch;margin-bottom:28px}

.card{background:var(--cloud);border:1px solid var(--line-soft);border-radius:16px;
  padding:22px;box-shadow:0 1px 0 rgba(255,255,255,.6) inset, 0 14px 30px rgba(15,33,26,.05)}
.grid{display:grid;gap:18px}

/* ===== Hero progress (signature) ===== */
.hero{position:relative;border-radius:20px;overflow:hidden;color:var(--mist);
  background:linear-gradient(165deg,#16382b,#0d1f18);padding:30px clamp(20px,4vw,40px);margin-bottom:26px}
.hero .row{display:flex;flex-wrap:wrap;gap:30px;align-items:flex-end;justify-content:space-between;position:relative;z-index:2}
.hero h2{font-family:var(--font-display);font-size:clamp(1.4rem,3vw,2rem);letter-spacing:.05em}
.hero .big{font-family:var(--font-data);font-size:clamp(3rem,9vw,5.2rem);line-height:.9;color:var(--alpen-soft)}
.hero .big span{font-size:1.4rem;color:var(--mist);opacity:.7;letter-spacing:.1em}
.hero .meta{font-size:.85rem;color:rgba(233,239,231,.75);margin-top:6px}
.profile-svg{width:100%;height:120px;display:block;margin-top:8px;position:relative;z-index:2}
.hero-break{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;position:relative;z-index:2}
.hero-break span{font-family:var(--font-data);font-size:.72rem;letter-spacing:.05em;
  color:rgba(233,239,231,.85);background:rgba(255,255,255,.09);border-radius:20px;padding:4px 11px}
.hero-break span b{color:var(--alpen-soft)}
.prof-label{font-family:var(--font-data);font-size:.7rem;letter-spacing:.15em;
  color:var(--bamboo);margin-top:20px;position:relative;z-index:2}

/* ===== stat tiles ===== */
.tiles{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:26px}
.tile{background:var(--cloud);border:1px solid var(--line-soft);border-radius:14px;padding:18px}
.tile .n{font-family:var(--font-data);font-size:2.1rem;color:var(--fir);line-height:1}
.tile .l{font-size:.8rem;color:var(--ridge);margin-top:6px}
.tile .k{font-family:var(--font-data);font-size:.62rem;letter-spacing:.3em;color:var(--bamboo);
  text-transform:uppercase}

.section-head{display:flex;align-items:baseline;justify-content:space-between;gap:16px;
  margin:34px 0 16px;padding-bottom:10px;border-bottom:1px solid var(--line)}
.section-head h3{font-family:var(--font-display);font-size:1.5rem;color:var(--pine);letter-spacing:.05em}
.section-head .hint{font-size:.78rem;color:var(--stone);font-family:var(--font-data);letter-spacing:.1em}

/* ===== category tabs ===== */
.cat-tabs{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px}
.cat-tabs button{padding:8px 16px;border-radius:9px;font-size:.92rem;color:var(--ridge);
  border:1px solid var(--line);background:#fff;transition:.18s}
.cat-tabs button:hover{border-color:var(--moss);color:var(--fir)}
.cat-tabs button.on{background:var(--fir);color:var(--cloud);border-color:var(--fir)}
.cat-progress{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}
.cat-progress .cp{font-family:var(--font-data);font-size:.74rem;letter-spacing:.06em;color:var(--ridge);
  background:var(--cloud);border:1px solid var(--line-soft);border-radius:20px;padding:5px 12px}
.cat-progress .cp b{color:var(--fir)}
.peak .badge.cat{background:rgba(95,115,117,.16);color:var(--ridge)}
/* ===== 百岳 list ===== */
.controls{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:18px;align-items:center}
.controls input,.controls select{padding:10px 12px;border:1px solid var(--line);border-radius:10px;background:#fff}
.controls input{flex:1;min-width:160px}
.chip{padding:7px 13px;border-radius:20px;font-size:.82rem;border:1px solid var(--line);
  color:var(--ridge);background:#fff;transition:all .18s}
.chip.on{background:var(--fir);color:var(--cloud);border-color:var(--fir)}
.peak-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px}
.peak{display:flex;align-items:center;gap:14px;padding:14px 16px;border-radius:12px;
  background:var(--cloud);border:1px solid var(--line-soft);transition:transform .15s,box-shadow .15s}
.peak:hover{transform:translateY(-2px);box-shadow:0 10px 22px rgba(15,33,26,.08)}
.peak .tog{width:26px;height:26px;border-radius:7px;border:2px solid var(--stone);flex:none;
  display:grid;place-items:center;transition:all .18s}
.peak.done .tog{background:var(--moss);border-color:var(--moss);color:#fff}
.peak .tog svg{width:14px;height:14px;opacity:0;transform:scale(.6);transition:.18s}
.peak.done .tog svg{opacity:1;transform:scale(1)}
.peak .info{flex:1;min-width:0}
.peak .nm{font-weight:600;color:var(--pine);font-size:1.02rem}
.peak.done .nm{color:var(--moss)}
.peak .sub{font-size:.74rem;color:var(--ridge);display:flex;gap:8px;flex-wrap:wrap;margin-top:1px}
.peak .badge{font-family:var(--font-data);font-size:.6rem;letter-spacing:.1em;padding:1px 6px;
  border-radius:5px;background:rgba(207,130,51,.14);color:var(--alpen)}
.peak .elev{font-family:var(--font-data);color:var(--ridge);font-size:.92rem;text-align:right;flex:none}
.peak .elev small{display:block;font-size:.55rem;letter-spacing:.2em}

/* ===== timeline ===== */
.timeline{position:relative;padding-left:30px}
.timeline::before{content:"";position:absolute;left:9px;top:6px;bottom:6px;width:2px;
  background:linear-gradient(var(--moss),var(--bamboo))}
.tl-item{position:relative;margin-bottom:22px}
.tl-item::before{content:"";position:absolute;left:-26px;top:5px;width:14px;height:14px;border-radius:50%;
  background:var(--cloud);border:3px solid var(--moss)}
.tl-date{font-family:var(--font-data);font-size:.72rem;letter-spacing:.15em;color:var(--alpen)}
.tl-card{background:var(--cloud);border:1px solid var(--line-soft);border-radius:12px;padding:14px 16px;margin-top:4px}
.tl-card h4{font-family:var(--font-display);font-size:1.15rem;color:var(--pine);letter-spacing:.03em}
.tl-card .loc{font-size:.82rem;color:var(--ridge);margin:3px 0 8px}
.tl-card .ppl{display:flex;flex-wrap:wrap;gap:5px}
.dot{font-size:.7rem;background:rgba(53,107,79,.1);color:var(--moss);padding:2px 9px;border-radius:12px}
.tl-card .note{font-size:.84rem;color:var(--ridge);margin-top:8px;border-top:1px dashed var(--line);padding-top:8px}

/* ===== charts ===== */
.charts{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:18px}
.chart-title{font-family:var(--font-display);font-size:1.15rem;color:var(--pine);margin-bottom:14px;letter-spacing:.03em}
.bar-row{display:flex;align-items:center;gap:10px;margin-bottom:9px}
.bar-row .lab{font-family:var(--font-data);font-size:.78rem;color:var(--ridge);width:54px;flex:none}
.bar-track{flex:1;height:22px;background:rgba(15,33,26,.05);border-radius:6px;overflow:hidden}
.bar-fill{height:100%;border-radius:6px;display:flex;align-items:center;justify-content:flex-end;
  padding-right:7px;color:#fff;font-family:var(--font-data);font-size:.72rem;min-width:24px;
  transition:width .8s cubic-bezier(.2,.8,.2,1)}
.year-cols{display:flex;align-items:flex-end;gap:clamp(8px,3vw,22px);height:200px;padding-top:10px}
.year-col{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%}
.year-col .colbar{width:100%;max-width:48px;border-radius:8px 8px 0 0;
  background:linear-gradient(var(--bamboo),var(--moss));transition:height .9s cubic-bezier(.2,.8,.2,1);
  position:relative;min-height:4px}
.year-col .colval{position:absolute;top:-22px;left:0;right:0;text-align:center;
  font-family:var(--font-data);font-size:.82rem;color:var(--fir)}
.year-col .colyr{font-family:var(--font-data);font-size:.78rem;color:var(--ridge);margin-top:8px}

/* ===== trips / planning ===== */
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-bottom:8px}
.form-grid label{display:block;font-size:.78rem;color:var(--moss);margin-bottom:5px;letter-spacing:.04em}
.form-grid input,.form-grid select{width:100%;padding:11px 13px;border:1px solid var(--line);border-radius:10px;background:#fff}
.peakpick{max-height:150px;overflow:auto;border:1px solid var(--line);border-radius:10px;padding:8px;background:#fff}
.peakpick label{display:flex;align-items:center;gap:8px;padding:5px 6px;border-radius:7px;font-size:.86rem;cursor:pointer}
.peakpick label:hover{background:rgba(53,107,79,.07)}
.peakpick input{width:auto}
.trip{border:1px solid var(--line-soft);border-radius:14px;padding:18px;background:var(--cloud);margin-bottom:14px}
.trip .th{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:wrap}
.trip h4{font-family:var(--font-display);font-size:1.3rem;color:var(--pine);letter-spacing:.03em}
.trip .when{font-family:var(--font-data);font-size:.8rem;color:var(--alpen);letter-spacing:.1em}
.trip .diff{font-size:.68rem;font-family:var(--font-data);letter-spacing:.12em;padding:3px 9px;border-radius:20px;white-space:nowrap}
.diff.d1{background:rgba(154,174,107,.25);color:#566b2e}
.diff.d2{background:rgba(207,130,51,.2);color:#a5651f}
.diff.d3{background:rgba(150,60,40,.18);color:#8c3320}
.trip .pks{font-size:.85rem;color:var(--ridge);margin:8px 0 12px}
.trip .foot{display:flex;align-items:center;gap:14px;flex-wrap:wrap;border-top:1px solid var(--line);padding-top:12px}
.capbar{flex:1;min-width:140px}
.capbar .ct{height:8px;background:rgba(15,33,26,.07);border-radius:5px;overflow:hidden;margin-top:5px}
.capbar .cf{height:100%;background:linear-gradient(90deg,var(--moss),var(--bamboo));border-radius:5px;transition:width .6s}
.capbar .clab{font-size:.74rem;color:var(--ridge);display:flex;justify-content:space-between}
.capbar .clab b{font-family:var(--font-data);color:var(--fir)}
.btn-sm{padding:9px 16px;border-radius:9px;font-size:.85rem;font-weight:600;letter-spacing:.05em;transition:.18s;white-space:nowrap}
.btn-join{background:var(--fir);color:var(--cloud)}.btn-join:hover{background:var(--pine)}
.btn-leave{background:rgba(150,60,40,.12);color:#8c3320}.btn-leave:hover{background:rgba(150,60,40,.2)}
.rsvp-names{font-size:.78rem;color:var(--ridge);width:100%;margin-top:2px}

/* ===== 行前須知 ===== */
.guide{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:18px}
.guide .card h4{font-family:var(--font-display);font-size:1.25rem;color:var(--pine);margin-bottom:4px;
  display:flex;align-items:center;gap:9px;letter-spacing:.03em}
.guide .card h4 .ic{width:30px;height:30px;border-radius:9px;background:rgba(53,107,79,.12);
  display:grid;place-items:center;color:var(--moss);flex:none;font-family:var(--font-data);font-size:.8rem}
.guide ul{list-style:none;margin-top:10px}
.guide li{padding:7px 0;border-bottom:1px solid var(--line-soft);font-size:.9rem;color:var(--ink);display:flex;gap:9px}
.guide li:last-child{border:none}
.guide li::before{content:"▲";color:var(--bamboo);font-size:.6rem;margin-top:5px}
.check li{cursor:pointer}
.check li .box{width:18px;height:18px;border:2px solid var(--stone);border-radius:5px;flex:none;
  display:grid;place-items:center;margin-top:2px;transition:.15s}
.check li::before{display:none}
.check li.ck .box{background:var(--moss);border-color:var(--moss)}
.check li.ck .box::after{content:"✓";color:#fff;font-size:.72rem}
.check li.ck span{text-decoration:line-through;color:var(--stone)}

/* ===== members / leaderboard / profile ===== */
.who-btn{display:flex;align-items:center;gap:10px;background:none;border:none;color:inherit;
  cursor:pointer;padding:3px 6px;border-radius:9px;transition:background .2s}
.who-btn:hover{background:rgba(255,255,255,.09)}
.who-btn .nm{display:block;font-size:.85rem}
.who-btn .ro{display:block;font-size:.65rem;color:var(--bamboo);font-family:var(--font-data);letter-spacing:.1em}

.members-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px}
.mcard{background:var(--cloud);border:1px solid var(--line-soft);border-radius:14px;padding:16px;
  cursor:pointer;transition:transform .15s,box-shadow .15s}
.mcard:hover{transform:translateY(-2px);box-shadow:0 10px 22px rgba(15,33,26,.08)}
.mcard .mc-top{display:flex;align-items:center;gap:12px}
.mcard .av{width:42px;height:42px;border-radius:50%;background:var(--moss);color:#fff;
  display:grid;place-items:center;font-family:var(--font-display);font-size:1.25rem;flex:none}
.mcard .mc-nm{font-family:var(--font-display);font-size:1.15rem;color:var(--pine);letter-spacing:.03em}
.mcard .mc-sub{font-size:.76rem;color:var(--ridge);font-family:var(--font-data)}
.mcard .mc-line{display:flex;justify-content:space-between;margin-top:12px;padding-top:10px;
  border-top:1px solid var(--line-soft);font-size:.78rem;color:var(--ridge)}
.mcard .mc-badge{color:var(--alpen);font-family:var(--font-data)}

.lb-row{display:flex;align-items:center;gap:12px;margin-bottom:11px;cursor:pointer;
  border-radius:10px;padding:4px;transition:background .15s}
.lb-row:hover{background:rgba(53,107,79,.06)}
.lb-row .rk{font-family:var(--font-data);width:24px;text-align:center;color:var(--ridge);font-size:.9rem;flex:none}
.lb-row.top .rk{color:var(--alpen);font-weight:700}
.lb-row .av{width:34px;height:34px;border-radius:50%;background:var(--moss);color:#fff;
  display:grid;place-items:center;font-family:var(--font-display);flex:none}
.lb-row.me .av{background:var(--alpen)}
.lb-row .meat{flex:1;min-width:0}
.lb-row .nm{font-size:.92rem;color:var(--pine);display:flex;justify-content:space-between;gap:10px}
.lb-row.me .nm{color:var(--moss);font-weight:700}
.lb-row .nm b{font-family:var(--font-data);color:var(--fir)}
.lb-row .tr{height:7px;background:rgba(15,33,26,.06);border-radius:5px;margin-top:5px;overflow:hidden}
.lb-row .fl{height:100%;background:linear-gradient(90deg,var(--moss),var(--bamboo));border-radius:5px;transition:width .7s cubic-bezier(.2,.8,.2,1)}

.modal{position:fixed;inset:0;z-index:80;display:none;align-items:flex-start;justify-content:center;
  padding:40px 16px;overflow:auto;background:rgba(10,22,17,.55);backdrop-filter:blur(3px)}
