function yearMap(){
  const m={};
  state.hikes.forEach(h=>{ const y=h.date.slice(0,4); m[y]=m[y]||{trips:0,peaks:0,ppl:0}; m[y].trips++; m[y].peaks+=h.peaks.length; m[y].ppl+=h.ppl.length; });
  return m;
}
function colChart(el,data,keyName){
  const yrs=Object.keys(data).sort();
  const max=Math.max(...yrs.map(y=>data[y][keyName]),1);
  el.innerHTML = yrs.map(y=>{
    const v=data[y][keyName]; const h=(v/max*100);
    return `<div class="year-col"><div class="colbar" style="height:0" data-h="${h}"><span class="colval">${v}</span></div><div class="colyr">${y}</div></div>`;
  }).join("");
  requestAnimationFrame(()=> $$(".colbar",el).forEach(b=> b.style.height=b.dataset.h+"%"));
}
function barList(el,pairs,unit){
  const max=Math.max(...pairs.map(p=>p[1]),1);
  el.innerHTML = pairs.map((p,i)=>{
    const w=p[1]/max*100;
    const col = i%2 ? "linear-gradient(90deg,var(--fir),var(--moss))" : "linear-gradient(90deg,var(--moss),var(--bamboo))";
    return `<div class="bar-row"><span class="lab">${p[0]}</span><div class="bar-track"><div class="bar-fill" style="width:0;background:${col}" data-w="${w}">${p[1]}${unit||""}</div></div></div>`;
  }).join("");
  requestAnimationFrame(()=> $$(".bar-fill",el).forEach(b=> b.style.width=b.dataset.w+"%"));
}
function renderStats(){
  const ym=yearMap();
  const totalPpl = state.hikes.reduce((s,h)=>s+h.ppl.length,0);
  const uniquePpl = new Set(state.hikes.flatMap(h=>h.ppl)).size;
  $("#statTiles").innerHTML = [
    {k:"OUTINGS",n:state.hikes.length,l:"總出隊次數"},
    {k:"PEAKS",n:state.hikes.reduce((s,h)=>s+h.peaks.length,0),l:"累積登頂人次"},
    {k:"HEADCOUNT",n:totalPpl,l:"累積參與人次"},
    {k:"MEMBERS",n:uniquePpl,l:"參與隊員數"}
  ].map(t=>`<div class="tile"><div class="k">${t.k}</div><div class="n">${t.n}</div><div class="l">${t.l}</div></div>`).join("");

  colChart($("#chartPeaksYr"),ym,"peaks");
  colChart($("#chartTripsYr"),ym,"trips");

  // participation per member
  const cnt={};
  state.hikes.forEach(h=>h.ppl.forEach(p=> cnt[p]=(cnt[p]||0)+1));
  const pairs=Object.entries(cnt).sort((a,b)=>b[1]-a[1]);
  barList($("#chartParticipants"),pairs," 次");

  // by region
  const rc={};
  state.hikes.forEach(h=>h.peaks.forEach(pn=>{ const pk=state.peaks.find(x=>x.name===pn); const r=pk?pk.region:"其他"; rc[r]=(rc[r]||0)+1; }));
  barList($("#chartRegions"),Object.entries(rc).sort((a,b)=>b[1]-a[1])," 座");
}

