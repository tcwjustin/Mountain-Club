const BADGES = [
  {name:"五岳",icon:"岳",desc:"玉山·雪山·秀姑巒·南湖·北大武",set:["玉山主峰","雪山主峰","秀姑巒山","南湖大山","北大武山"]},
  {name:"三尖",icon:"尖",desc:"中央尖·大霸尖·達芬尖",set:["中央尖山","大霸尖山","達芬尖山"]},
  {name:"武陵四秀",icon:"秀",desc:"品田·池有·桃山·喀拉業",set:["品田山","池有山","桃山","喀拉業山"]},
  {name:"合歡群峰",icon:"歡",desc:"合歡主東北西·石門山",set:["合歡主峰","合歡東峰","合歡北峰","合歡山西峰","石門山"]}
];
const MILESTONES = [10,25,50,100];
const LB = [
  {k:"outings",l:"出隊次數",u:" 次"},
  {k:"bai",l:"百岳",u:" 座"},
  {k:"summits",l:"山岳總數",u:" 座"},
  {k:"elev",l:"累積爬升",u:" m"}
];
let lbMetric = "outings";

function memberStats(name){
  const hs = state.hikes.filter(h=> h.ppl.includes(name));
  const peakNames = new Set(hs.flatMap(h=>h.peaks));
  const peaks = [...peakNames].map(pn=> state.peaks.find(p=>p.name===pn)).filter(Boolean);
  const cnt = c=> peaks.filter(p=>p.cat===c).length;
  return {
    name, hikes:hs, peakNames, peaks,
    outings:hs.length,
    baiCount:cnt("百岳"), xiaoCount:cnt("小百岳"), zhongCount:cnt("中級山"), otherCount:cnt("其他"),
    elev:peaks.reduce((s,p)=>s+p.elev,0),
    highest:peaks.reduce((m,p)=>Math.max(m,p.elev),0)
  };
}
function allMemberStats(){ return memberNames().map(memberStats); }
function metricVal(s,k){ return k==="outings"?s.outings : k==="bai"?s.baiCount : k==="summits"?s.peaks.length : s.elev; }

function badgeState(s){
  const has = n=> s.peakNames.has(n);
  const list = BADGES.map(b=>{ const have=b.set.filter(has).length;
    return {name:b.name,icon:b.icon,desc:b.desc,have,need:b.set.length,earned:have===b.set.length}; });
  MILESTONES.forEach(m=> list.push({name:`百岳 ${m}`,icon:"百",desc:`累積 ${m} 座百岳`,have:Math.min(s.baiCount,m),need:m,earned:s.baiCount>=m}));
  list.push({name:"小百岳獵人",icon:"郊",desc:"完成 5 座小百岳",have:Math.min(s.xiaoCount,5),need:5,earned:s.xiaoCount>=5});
  list.push({name:"中級山開拓",icon:"中",desc:"完成 5 座中級山",have:Math.min(s.zhongCount,5),need:5,earned:s.zhongCount>=5});
  return list;
}

function renderMembers(){
  $("#lbChips").innerHTML = LB.map(m=>`<button class="chip ${m.k===lbMetric?'on':''}" data-m="${m.k}">${m.l}</button>`).join("");
  $$("#lbChips .chip").forEach(c=> c.onclick=()=>{ lbMetric=c.dataset.m; renderMembers(); });

  const stats = allMemberStats();
  const unit = LB.find(m=>m.k===lbMetric).u;
  const sorted = [...stats].sort((a,b)=> metricVal(b,lbMetric)-metricVal(a,lbMetric));
  const max = Math.max(...sorted.map(s=>metricVal(s,lbMetric)),1);
  $("#lbRows").innerHTML = sorted.map((s,i)=>{
    const v=metricVal(s,lbMetric); const me=state.user && s.name===state.user.name;
    return `<div class="lb-row ${i<3?'top':''} ${me?'me':''}" data-name="${s.name}">
      <span class="rk">${i+1}</span><span class="av">${s.name.charAt(0)}</span>
      <div class="meat"><div class="nm"><span>${s.name}${me?' · 你':''}</span><b>${v.toLocaleString()}${unit}</b></div>
        <div class="tr"><div class="fl" style="width:0" data-w="${v/max*100}"></div></div></div>
    </div>`;
  }).join("");
  requestAnimationFrame(()=> $$("#lbRows .fl").forEach(f=> f.style.width=f.dataset.w+"%"));
  $$("#lbRows .lb-row").forEach(r=> r.onclick=()=> openProfile(r.dataset.name));

  $("#membersGrid").innerHTML = stats.map(s=>{
    const badges=badgeState(s); const earned=badges.filter(b=>b.earned).length;
    return `<div class="mcard" data-name="${s.name}">
      <div class="mc-top"><span class="av">${s.name.charAt(0)}</span>
        <div><div class="mc-nm">${s.name}</div><div class="mc-sub">${memberRole(s.name)} · 出隊 ${s.outings} · 百岳 ${s.baiCount}</div></div></div>
      <div class="mc-line"><span>最高 ${s.highest?s.highest.toLocaleString()+'m':'—'}</span><span class="mc-badge">徽章 ${earned}/${badges.length}</span></div>
    </div>`;
  }).join("");
  $$("#membersGrid .mcard").forEach(c=> c.onclick=()=> openProfile(c.dataset.name));
  renderManage();
  saveState();
}

function openProfile(name){
  const s = memberStats(name);
  const badges = badgeState(s); const earned = badges.filter(b=>b.earned).length;
  const m = findMember(name);
  const showContact = m && (canManage() || (state.user && name===state.user.name));
  const contactLine = (showContact && (m.phone||m.emergency)) ? `<br>聯絡 ${m.phone||'—'} · 緊急聯絡 ${m.emergency||'—'}` : "";
  const tiles = [
    {k:"SUMMITS",n:s.peaks.length,l:"登頂山岳"},
    {k:"百岳",n:`${s.baiCount}/100`,l:"百岳進度"},
    {k:"OUTINGS",n:s.outings,l:"出隊次數"},
    {k:"HIGHEST",n:s.highest?s.highest.toLocaleString():"—",l:"最高（公尺）"}
  ];
  const catPairs = [["百岳",s.baiCount],["小百岳",s.xiaoCount],["中級山",s.zhongCount],["其他",s.otherCount]];
  $("#profileBox").innerHTML = `
    <button class="x" id="closeProfile" aria-label="關閉">✕</button>
    <div class="p-head"><span class="pav">${name.charAt(0)}</span>
      <div><h3>${name}</h3><div class="pr">${memberRole(name)}${state.user&&name===state.user.name?' · 你':''}</div></div></div>
    <div class="p-note">依社團出隊紀錄統計 · 已獲得 ${earned} / ${badges.length} 枚徽章${contactLine}</div>
    <div class="tiles">${tiles.map(t=>`<div class="tile"><div class="k">${t.k}</div><div class="n">${t.n}</div><div class="l">${t.l}</div></div>`).join("")}</div>
    <div class="section-head"><h3>成就徽章</h3><span class="hint">BADGES</span></div>
    <div class="badges">${badges.map(b=>`<div class="badge-item ${b.earned?'earned':''}" title="${b.desc}"><div class="bic">${b.icon}</div><div class="bn">${b.name}</div><div class="bp">${b.earned?'已達成':`${b.have} / ${b.need}`}</div></div>`).join("")}</div>
    <div class="section-head"><h3>分類分布</h3><span class="hint">BY TYPE</span></div>
    <div class="card" id="pCat"></div>
    <div class="section-head"><h3>出隊足跡</h3><span class="hint">LOG</span></div>
    <div class="timeline" id="pTimeline"></div>`;
  barList($("#pCat"),catPairs," 座");
  $("#pTimeline").innerHTML = s.hikes.length ? renderTimeline([...s.hikes].sort((a,b)=>b.date.localeCompare(a.date))) : `<div class="empty">尚無出隊紀錄</div>`;
  $("#closeProfile").onclick = closeProfile;
  $("#profileModal").classList.add("on");
}
function closeProfile(){ $("#profileModal").classList.remove("on"); }

/* ============================================================
   人員管理（限社長 / 副社長 / 幹部）
   ============================================================ */
function renderManage(){
  const wrap=$("#manageWrap");
  if(!canManage()){ wrap.innerHTML=""; return; }
  const activeCount = state.members.filter(m=>m.active).length;
  const rows = state.members.map(m=>`
    <div class="mrow ${m.active?'':'inactive'}" data-id="${m.id}">
      <span class="av">${m.name.charAt(0)}</span>
      <span class="mname">${m.name}</span>
      <select class="mrole" data-id="${m.id}">${ROLES.map(r=>`<option ${r===m.role?'selected':''}>${r}</option>`).join("")}</select>
      <span class="mstat ${m.active?'on':''}">${m.active?'在籍':'已退社'}</span>
      <button class="mbtn medit" data-id="${m.id}">編輯</button>
      <button class="mbtn" data-toggle="${m.id}">${m.active?'退社':'復籍'}</button>
    </div>`).join("");
  wrap.innerHTML = `
    <div class="section-head"><h3>隊員管理</h3><span class="hint">ROSTER · ${memberRole(state.user.name)}</span></div>
    <div class="card">
      <div class="chart-title">新增隊員</div>
      <div class="form-grid">
        <div><label>姓名</label><input id="nmName" placeholder="隊員姓名"></div>
        <div><label>職務</label><select id="nmRole">${ROLES.map(r=>`<option ${r==='隊員'?'selected':''}>${r}</option>`).join("")}</select></div>
        <div><label>電話</label><input id="nmPhone" placeholder="選填"></div>
        <div><label>緊急聯絡</label><input id="nmEmer" placeholder="選填"></div>
        <div><label>Google 登入 Email</label><input id="nmEmail" type="email" placeholder="白名單用，建議填"></div>
      </div>
      <button class="btn-sm btn-join" id="nmAdd">新增隊員</button>
    </div>
    <div class="card" style="margin-top:16px">
      <div class="chart-title">名冊（在籍 ${activeCount} 人 / 共 ${state.members.length} 人）</div>
      <div class="roster">${rows}</div>
    </div>`;
  $("#nmAdd").onclick = addMember;
  $$(".mrole").forEach(sel=> sel.onchange=()=>{
    const m=state.members.find(x=>x.id===+sel.dataset.id); m.role=sel.value;
    if(state.user && state.user.name===m.name){ state.user.role=m.role; $("#whoRole").textContent=m.role; }
    toast(`${m.name} 職務改為 ${m.role}`);
    saveState();
  });
  $$("#manageWrap [data-toggle]").forEach(b=> b.onclick=()=>{
    const m=state.members.find(x=>x.id===+b.dataset.toggle); m.active=!m.active;
    toast(m.active?`${m.name} 已復籍`:`${m.name} 已退社`); renderMembers();
  });
  $$("#manageWrap .medit").forEach(b=> b.onclick=()=> openMemberEdit(+b.dataset.id));
}
function addMember(){
  const name=$("#nmName").value.trim();
  if(!name){ toast("請輸入姓名"); return; }
  if(findMember(name)){ toast("已有同名隊員"); return; }
  state.members.push({id:memberSeq++, name, role:$("#nmRole").value, phone:$("#nmPhone").value.trim(), emergency:$("#nmEmer").value.trim(), email:$("#nmEmail").value.trim(), joined:new Date().toISOString().slice(0,10), active:true});
  toast(`已新增隊員：${name}`);
  renderMembers();
}
function openMemberEdit(id){
  const m=state.members.find(x=>x.id===id); if(!m) return;
  const hasRecord = state.hikes.some(h=>h.ppl.includes(m.name)) || state.trips.some(t=>t.rsvp.includes(m.name));
  $("#memberBox").innerHTML = `
    <button class="x" id="meClose" aria-label="關閉">✕</button>
    <div class="p-head"><span class="pav">${m.name.charAt(0)}</span><div><h3>編輯隊員</h3><div class="pr">入社 ${m.joined||'—'}</div></div></div>
    <div class="form-grid" style="margin-top:10px">
      <div><label>姓名</label><input id="meName" value="${m.name}"></div>
      <div><label>職務</label><select id="meRole">${ROLES.map(r=>`<option ${r===m.role?'selected':''}>${r}</option>`).join("")}</select></div>
      <div><label>電話</label><input id="mePhone" value="${m.phone||''}"></div>
      <div><label>緊急聯絡</label><input id="meEmer" value="${m.emergency||''}"></div>
      <div><label>Google 登入 Email</label><input id="meEmail" type="email" value="${m.email||''}"></div>
      <div><label>入社日期</label><input id="meJoined" type="date" value="${m.joined||''}"></div>
      <div><label>狀態</label><select id="meActive"><option value="1" ${m.active?'selected':''}>在籍</option><option value="0" ${!m.active?'selected':''}>已退社</option></select></div>
    </div>
    <div style="display:flex;gap:10px;margin-top:18px;flex-wrap:wrap">
      <button class="btn-sm btn-join" id="meSave">儲存變更</button>
      <button class="btn-sm btn-leave" id="meDelete" ${hasRecord?'disabled style="opacity:.4;cursor:not-allowed"':''}>刪除</button>
    </div>
    ${hasRecord?'<div class="p-note">此隊員已有出隊或報名紀錄，無法刪除；若已離開請改用「退社」以保留歷史。</div>':''}`;
  $("#meClose").onclick=()=> $("#memberModal").classList.remove("on");
  $("#meSave").onclick=()=>{
    const newName=$("#meName").value.trim();
    if(!newName){ toast("姓名不可空白"); return; }
    if(newName!==m.name && findMember(newName)){ toast("已有同名隊員"); return; }
    const old=m.name;
    if(newName!==old){
      state.hikes.forEach(h=> h.ppl=h.ppl.map(p=>p===old?newName:p));
      state.trips.forEach(t=> t.rsvp=t.rsvp.map(p=>p===old?newName:p));
      if(state.user && state.user.name===old){ state.user.name=newName; $("#whoName").textContent=newName; $("#avatar").textContent=newName.charAt(0); }
    }
    m.name=newName; m.role=$("#meRole").value; m.phone=$("#mePhone").value.trim();
    m.emergency=$("#meEmer").value.trim(); m.joined=$("#meJoined").value; m.active=$("#meActive").value==="1";
    m.email=$("#meEmail").value.trim();
    if(state.user && state.user.name===m.name){ state.user.role=m.role; $("#whoRole").textContent=m.role; }
    $("#memberModal").classList.remove("on"); toast("已儲存變更");
    renderMembers(); renderHome();
  };
  if(!hasRecord) $("#meDelete").onclick=()=>{
    state.members=state.members.filter(x=>x.id!==id);
    $("#memberModal").classList.remove("on"); toast(`已刪除：${m.name}`); renderMembers();
  };
  $("#memberModal").classList.add("on");
}

