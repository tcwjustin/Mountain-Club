function renderPeaks(){
  const q=$("#peakSearch").value.trim();
  const reg=$("#peakRegion").value;
  let list = state.peaks.filter(p=>{
    if(q && !p.name.includes(q)) return false;
    if(reg && p.region!==reg) return false;
    if(peakCat!=="all" && p.cat!==peakCat) return false;
    if(peakFilter==="done" && !p.climbed) return false;
