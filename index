<script type="module">
/* ===========================================================================
   雲端設定（Firebase）
   ─ 未填寫時：以「本機示範模式」運作（可離線預覽，重整會回到範本）
   ─ 填好並部署後：自動切換成「雲端版」（多人共用、即時同步、永久保存）
   登入方式：Google 登入。能否進入由「白名單」決定——
   只有 Email 在名冊裡、且為在籍狀態的 Google 帳號才放行；不開放自行註冊。
   把 PASTE_... 換成你 Firebase 專案的網頁設定值，ADMIN_EMAIL 換成你的 Gmail。
   完整步驟見 README.md。
   =========================================================================== */
const firebaseConfig = {
  apiKey:     "PASTE_API_KEY",
  authDomain: "PASTE_PROJECT.firebaseapp.com",
  projectId:  "PASTE_PROJECT_ID",
  appId:      "PASTE_APP_ID"
};
const ADMIN_EMAIL = "";   // 你的 Gmail，例："you@gmail.com"。此帳號永遠可登入，且首次登入自動成為系統管理員

let FB_ENABLED = !firebaseConfig.apiKey.includes("PASTE");
let A=null, S=null, fbAuth=null, clubRef=null;
let authEmail=null, authName=null, dataReady=false, appShown=false, subscribed=false, remoteApplying=false, saveTimer=null;

if(FB_ENABLED){
  try{
    const appMod = await import("https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js");
    A = await import("https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js");
    S = await import("https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js");
    const app = appMod.initializeApp(firebaseConfig);
    fbAuth = A.getAuth(app);
    clubRef = S.doc(S.getFirestore(app), "clubs", "main");
    A.onAuthStateChanged(fbAuth, u=>{
      if(!u){ authEmail=null; appShown=false; document.querySelector("#app").classList.remove("on"); document.querySelector("#login").style.display="flex"; return; }
      authEmail = u.email; authName = u.displayName;
      startSubscribe(); tryEnter();
    });
  }catch(err){ console.error("Firebase 載入失敗，改用本機模式：", err); FB_ENABLED=false; }
}

function serializeState(){ return { members:state.members, peaks:state.peaks, hikes:state.hikes, trips:state.trips, seqs:{tripSeq, memberSeq, peakSeq} }; }
function saveState(){
  if(!FB_ENABLED || !clubRef || remoteApplying || !state.user) return;
  clearTimeout(saveTimer);
  saveTimer = setTimeout(()=> S.setDoc(clubRef, serializeState()).catch(e=>console.error("儲存失敗：",e)), 400);
}
function applyRemote(d){
  remoteApplying = true;
  if(d.members) state.members = d.members;
  if(d.peaks)   state.peaks   = d.peaks;
  if(d.hikes)   state.hikes   = d.hikes;
  if(d.trips)   state.trips   = d.trips;
  if(d.seqs){ tripSeq=d.seqs.tripSeq||tripSeq; memberSeq=d.seqs.memberSeq||memberSeq; peakSeq=d.seqs.peakSeq||peakSeq; }
  if(state.user) renderAll();
  remoteApplying = false;
}
function startSubscribe(){
  if(subscribed) return; subscribed = true;
  S.onSnapshot(clubRef, snap=>{
    if(snap.exists()) applyRemote(snap.data());
    else S.setDoc(clubRef, serializeState()).catch(e=>console.error(e));  // 首次：把種子資料寫上雲端
    dataReady = true; tryEnter();
  }, err=> console.error("讀取失敗：", err));
}
/* Google 登入成功後，比對白名單（email 是否在名冊且在籍） */
function tryEnter(){
  if(!authEmail || !dataReady || appShown) return;
  const em = authEmail.toLowerCase();
  let m = state.members.find(x=> x.email && x.email.toLowerCase()===em && x.active);
  if(!m){
    if(ADMIN_EMAIL && em===ADMIN_EMAIL.toLowerCase()){
      m = { id:memberSeq++, name:(authName||authEmail.split("@")[0]), role:"系統管理員",
            email:authEmail, phone:"", emergency:"", joined:new Date().toISOString().slice(0,10), active:true };
      state.members.push(m);
    } else {
      toast("你的 Google 帳號不在名單中，請聯絡管理員");
      try{ A.signOut(fbAuth); }catch(e){}
      authEmail=null; return;
    }
  }
  appShown = true;
  enterApp(m.name, m.role);
  saveState();
}

