// signature: 完成的山頭浮出雲海
function drawProfile(done,total){
  const svg=$("#profileSvg"); const W=1000,H=120, n=40;
  const ratio = done/total;
  let path=`M0,${H} `;
  const pts=[];
  for(let i=0;i<=n;i++){
    const x=i/n*W;
    const base=H-30;
    const peak = 22 + Math.abs(Math.sin(i*1.7)*Math.cos(i*0.6))*55;
    const y = base - peak;
    pts.push([x,y]);
  }
  pts.forEach((p,i)=> path += (i?`L`:``)+`${p[0].toFixed(0)},${p[1].toFixed(0)} `);
  path += `L${W},${H} Z`;
  const cloudY = H-30 - (H-50)*ratio*0.0 + (1-ratio)*38; // cloud line drops as progress rises
  const frontX = ratio*W;
  svg.innerHTML = `
    <defs>
      <linearGradient id="rg" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#e7b06a"/><stop offset="1" stop-color="#356b4f"/>
      </linearGradient>
      <linearGradient id="clip-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#fff" stop-opacity="0"/><stop offset=".55" stop-color="#fff" stop-opacity=".9"/>
      </linearGradient>
      <clipPath id="doneClip"><rect x="0" y="0" width="${frontX}" height="${H}"/></clipPath>
    </defs>
    <path d="${path}" fill="#0a1812" opacity=".55"/>
    <path d="${path}" fill="url(#rg)" clip-path="url(#doneClip)"/>
    <rect x="0" y="${(H- (H*0.46)).toFixed(0)}" width="${W}" height="${(H*0.46).toFixed(0)}" fill="url(#clip-grad)" opacity=".5"/>
    <line x1="${frontX}" y1="6" x2="${frontX}" y2="${H}" stroke="#e7b06a" stroke-width="2" stroke-dasharray="3 5" opacity=".8"/>
    <circle cx="${frontX}" cy="20" r="9" fill="#e7b06a"/>
  `;
}

