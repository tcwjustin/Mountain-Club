          <div class="rsvp-names">${t.rsvp.map(p=>p).join("、")||"尚無人報名"}</div>
        </div>
        <button class="btn-sm ${me?'btn-leave':'btn-join'}" ${full?'disabled style="opacity:.4;cursor:not-allowed"':''}>${me?'取消報名':(full?'已額滿':'我要報名')}</button>
      </div>
    </div>`;
  }).join("") : `<div class="empty">目前沒有規劃中的行程，建立第一場吧。</div>`;

  $$("#tripList .trip").forEach(el=>{
    const btn=el.querySelector("button"); if(btn.disabled) return;
    btn.onclick=()=>{
      const t=state.trips.find(x=>x.id===+el.dataset.id);
      const i=t.rsvp.indexOf(state.user.name);
      if(i>=0){ t.rsvp.splice(i,1); toast("已取消報名"); }
      else { t.rsvp.push(state.user.name); toast(`已報名：${t.title}`); }
      renderTrips(); renderHome(); renderStats();
    };
  });
}

